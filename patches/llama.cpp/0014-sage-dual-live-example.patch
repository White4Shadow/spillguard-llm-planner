+struct dual_params {
+    std::string proxy_model;
+    std::string oracle_model;
+    std::string prompt = "The capital of France is";
+    std::string json_out;
+    int proxy_ngl = 99;
+    int oracle_ngl = 99;
+    int n_predict = 16;
+    int n_ctx = 0;
+    int kv_hot_recent_tokens = 512;
+    int kv_sink_tokens = 16;
+    int kv_warm_max_tokens = 3584;
+    int kv_warm_bits = 2;
+    int kv_cold_summary_dim = 256;
+    int kv_cold_summary_bits = 8;
+    int logit_top_k = 10;
+};
+
+struct token_score {
+    llama_token id = LLAMA_TOKEN_NULL;
+    double logit = -std::numeric_limits<double>::infinity();
+};
+
+struct logit_stats {
+    llama_token top1_id = LLAMA_TOKEN_NULL;
+    llama_token top2_id = LLAMA_TOKEN_NULL;
+    double top1_logit = -std::numeric_limits<double>::infinity();
+    double top2_logit = -std::numeric_limits<double>::infinity();
+    double margin = 0.0;
+    double entropy = 0.0;
+    std::vector<token_score> top;
+};
+
+struct generated_token {
+    bool ok = false;
+    bool eog = false;
+    llama_token id = LLAMA_TOKEN_NULL;
+    std::string piece;
+    std::string cls;
+    logit_stats stats;
+    int position = 0;
+};
