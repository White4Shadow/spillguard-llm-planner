+    llama_context * ctx = nullptr;
+    llama_sampler * sampler = nullptr;
+    const llama_vocab * vocab = nullptr;
+    std::vector<llama_token> pending;
+    int n_pos = 0;
+    int n_vocab = 0;
+    int decode_calls = 0;
+    int accepted_text_tokens = 0;
+    uint64_t model_size_bytes = 0;
+    uint64_t n_params = 0;
+    int n_layer = 0;
+    int n_embd = 0;
+    int n_head = 0;
+    int n_head_kv = 0;
+    uint64_t kv_bytes_per_token_estimate = 0;
+};
