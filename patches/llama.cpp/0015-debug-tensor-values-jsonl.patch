+static void common_debug_write_tensor_values_jsonl(
+        std::ostream &             out,
+        int64_t                    sequence,
+        const struct ggml_tensor * t,
+        uint8_t *                  data,
+        int32_t                    value_limit,
+        int32_t                    requested_i1) {
+    const int64_t n0 = t->ne[0];
+    const int64_t n1 = t->ne[1];
+    if (n0 <= 0 || n1 <= 0 || value_limit <= 0) {
+        return;
+    }
+    int64_t i1 = requested_i1 < 0 ? n1 - 1 : requested_i1;
+    if (i1 < 0) {
+        i1 = 0;
+    }
+    if (i1 >= n1) {
+        i1 = n1 - 1;
+    }
+    const int64_t n_emit = std::min<int64_t>(n0, value_limit);
+
+    out << "{\"sequence\":" << (long long) sequence;
+    out << ",\"name\":";
+    common_debug_write_json_string(out, t->name);
+    out << ",\"dtype\":";
+    common_debug_write_json_string(out, ggml_type_name(t->type));
+    out << ",\"op\":";
+    common_debug_write_json_string(out, ggml_op_desc(t));
+    out << ",\"shape\":[" << (long long) t->ne[0] << ',' << (long long) t->ne[1] << ','
+        << (long long) t->ne[2] << ',' << (long long) t->ne[3] << ']';
+    out << ",\"i1\":" << (long long) i1;
+    out << ",\"axis\":\"i0\"";
+    out << ",\"count\":" << (long long) n0;
+    out << ",\"emitted\":" << (long long) n_emit;
+    out << ",\"truncated\":" << (n_emit < n0 ? "true" : "false");
+    out << ",\"values\":[";
+    for (int64_t i0 = 0; i0 < n_emit; ++i0) {
+        if (i0 > 0) {
+            out << ',';
+        }
+        common_debug_write_json_number(out, common_ggml_get_float_value(data, t->type, t->nb, i0, i1, 0, 0));
+    }
+    out << "]}\n";
+}
