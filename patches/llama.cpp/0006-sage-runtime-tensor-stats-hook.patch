diff --git a/common/sage.cpp b/common/sage.cpp
new file mode 100644
index 00000000..c1e73907
--- /dev/null
+++ b/common/sage.cpp
@@ -0,0 +1,208 @@
+#include "sage.h"
+
+#include "common.h"
+
+#include <cmath>
+#include <fstream>
+#include <iomanip>
+#include <ostream>
+#include <regex>
+#include <stdexcept>
+#include <string>
+#include <vector>
+
+struct common_sage_tensor_stats {
+    int64_t count     = 0;
+    double  sum       = 0.0;
+    double  mean      = 0.0;
+    float   min_value = 0.0f;
+    float   max_value = 0.0f;
+    int64_t nan_count = 0;
+};
+
+struct common_sage_cb_user_data::impl {
+    std::vector<uint8_t>    data;
+    std::vector<std::regex> tensor_filters;
+    std::ofstream           output;
+    int64_t                 sequence{0};
+};
+
+common_sage_cb_user_data::common_sage_cb_user_data() : pimpl(std::make_unique<impl>()) {}
+common_sage_cb_user_data::~common_sage_cb_user_data() = default;
+
+common_sage_cb_user_data::common_sage_cb_user_data(const std::vector<std::string> & filter_patterns, const std::string & output_path)
+    : pimpl(std::make_unique<impl>())
+{
+    for (const auto & pattern : filter_patterns) {
+        try {
+            std::string anchored_pattern = "^" + pattern;
+            pimpl->tensor_filters.emplace_back(anchored_pattern, std::regex::optimize);
+        } catch (const std::regex_error & e) {
+            throw std::runtime_error("Invalid SAGE tensor regex pattern '" + pattern + "': " + e.what());
+        }
+    }
+
+    pimpl->output.open(output_path, std::ios::out | std::ios::trunc);
+    if (!pimpl->output.is_open()) {
+        throw std::runtime_error("failed to open --sage-tensor-stats-output: " + output_path);
+    }
+}
+
+static float common_sage_get_float_value(
+        const uint8_t * data,
+        ggml_type       type,
+        const size_t *  nb,
+        size_t          i0,
+        size_t          i1,
+        size_t          i2,
+        size_t          i3) {
+    const size_t i = i3 * nb[3] + i2 * nb[2] + i1 * nb[1] + i0 * nb[0];
+    if (type == GGML_TYPE_F16) {
+        return ggml_fp16_to_fp32(*(const ggml_fp16_t *) &data[i]);
+    }
+    if (type == GGML_TYPE_F32) {
+        return *(const float *) &data[i];
+    }
+    if (type == GGML_TYPE_I64) {
+        return (float) *(const int64_t *) &data[i];
+    }
+    if (type == GGML_TYPE_I32) {
+        return (float) *(const int32_t *) &data[i];
+    }
+    if (type == GGML_TYPE_I16) {
+        return (float) *(const int16_t *) &data[i];
+    }
+    if (type == GGML_TYPE_I8) {
+        return (float) *(const int8_t *) &data[i];
+    }
+    if (type == GGML_TYPE_BF16) {
+        return ggml_bf16_to_fp32(*(const ggml_bf16_t *) &data[i]);
+    }
+    GGML_ABORT("fatal error");
+}
+
+static common_sage_tensor_stats common_sage_compute_tensor_stats(
+        const uint8_t * data,
+        ggml_type       type,
+        const int64_t * ne,
+        const size_t *  nb) {
+    common_sage_tensor_stats stats;
+    for (int64_t i3 = 0; i3 < ne[3]; i3++) {
+        for (int64_t i2 = 0; i2 < ne[2]; i2++) {
+            for (int64_t i1 = 0; i1 < ne[1]; i1++) {
+                for (int64_t i0 = 0; i0 < ne[0]; i0++) {
+                    const float v = common_sage_get_float_value(data, type, nb, i0, i1, i2, i3);
+                    if (stats.count == 0 || v < stats.min_value) {
+                        stats.min_value = v;
+                    }
+                    if (stats.count == 0 || v > stats.max_value) {
+                        stats.max_value = v;
+                    }
+                    if (std::isnan(v)) {
+                        stats.nan_count++;
+                    }
+                    stats.sum += v;
+                    stats.count++;
+                }
+            }
+        }
+    }
+    stats.mean = stats.count > 0 ? stats.sum / double(stats.count) : 0.0;
+    return stats;
+}
+
+static void common_sage_write_json_string(std::ostream & out, const char * value) {
+    out << '"';
+    for (const char * p = value; *p != '\0'; ++p) {
+        const unsigned char c = (unsigned char) *p;
+        switch (c) {
+            case '"':  out << "\\\""; break;
+            case '\\': out << "\\\\"; break;
+            case '\b': out << "\\b";  break;
+            case '\f': out << "\\f";  break;
+            case '\n': out << "\\n";  break;
+            case '\r': out << "\\r";  break;
+            case '\t': out << "\\t";  break;
+            default:
+                out << (c < 0x20 ? '?' : (char) c);
+                break;
+        }
+    }
+    out << '"';
+}
+
+static void common_sage_write_json_number(std::ostream & out, double value) {
+    if (std::isfinite(value)) {
+        out << std::setprecision(17) << value;
+    } else {
+        out << "null";
+    }
+}
+
+static void common_sage_write_jsonl(
+        std::ostream &                    out,
+        int64_t                           sequence,
+        const struct ggml_tensor *        t,
+        const common_sage_tensor_stats &  stats) {
+    out << "{\"sequence\":" << (long long) sequence;
+    out << ",\"name\":";
+    common_sage_write_json_string(out, t->name);
+    out << ",\"dtype\":";
+    common_sage_write_json_string(out, ggml_type_name(t->type));
+    out << ",\"op\":";
+    common_sage_write_json_string(out, ggml_op_desc(t));
+    out << ",\"shape\":[";
+    for (int i = 0; i < GGML_MAX_DIMS; ++i) {
+        if (i > 0) {
+            out << ',';
+        }
+        out << (long long) t->ne[i];
+    }
+    out << "],\"count\":" << (long long) stats.count;
+    out << ",\"sum\":";
+    common_sage_write_json_number(out, stats.sum);
+    out << ",\"mean\":";
+    common_sage_write_json_number(out, stats.mean);
+    out << ",\"min\":";
+    common_sage_write_json_number(out, stats.min_value);
+    out << ",\"max\":";
+    common_sage_write_json_number(out, stats.max_value);
+    out << ",\"nan_count\":" << (long long) stats.nan_count << "}\n";
+}
+
+bool common_sage_cb_eval(struct ggml_tensor * t, bool ask, void * user_data) {
+    auto * cb_data = (common_sage_cb_user_data *) user_data;
+    auto * pimpl = cb_data->pimpl.get();
+
+    bool matches_filter = pimpl->tensor_filters.empty();
+    if (!matches_filter) {
+        for (const auto & filter : pimpl->tensor_filters) {
+            if (std::regex_search(t->name, filter)) {
+                matches_filter = true;
+                break;
+            }
+        }
+    }
+
+    if (ask) {
+        return matches_filter && !ggml_is_quantized(t->type);
+    }
+
+    if (!matches_filter || ggml_is_quantized(t->type)) {
+        return true;
+    }
+
+    const bool is_host = ggml_backend_buffer_is_host(t->buffer);
+    if (!is_host) {
+        const size_t n_bytes = ggml_nbytes(t);
+        pimpl->data.resize(n_bytes);
+        ggml_backend_tensor_get(t, pimpl->data.data(), 0, n_bytes);
+    }
+
+    const uint8_t * data = is_host ? (const uint8_t *) t->data : pimpl->data.data();
+    const common_sage_tensor_stats stats = common_sage_compute_tensor_stats(data, t->type, t->ne, t->nb);
+    common_sage_write_jsonl(pimpl->output, pimpl->sequence++, t, stats);
+    pimpl->output.flush();
+
+    return true;
+}
diff --git a/common/sage.h b/common/sage.h
new file mode 100644
index 00000000..24ed465c
--- /dev/null
+++ b/common/sage.h
@@ -0,0 +1,24 @@
+#pragma once
+
+#include <memory>
+#include <string>
+#include <vector>
+
+// SAGE runtime tensor-stat callback.
+//
+// This is intended for normal generation paths that need a small scheduler-facing
+// verifier signal without using llama-debug tensor dumps.
+bool common_sage_cb_eval(struct ggml_tensor * t, bool ask, void * user_data);
+
+struct common_sage_cb_user_data {
+    struct impl;
+    std::unique_ptr<impl> pimpl;
+
+    common_sage_cb_user_data();
+    ~common_sage_cb_user_data();
+
+    common_sage_cb_user_data(const common_sage_cb_user_data &) = delete;
+    common_sage_cb_user_data & operator=(const common_sage_cb_user_data &) = delete;
+
+    common_sage_cb_user_data(const std::vector<std::string> & filter_patterns, const std::string & output_path);
+};
