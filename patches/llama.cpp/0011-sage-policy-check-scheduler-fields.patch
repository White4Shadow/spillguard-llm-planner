+static bool json_has_string(const json & row, const char * key) {
+    return row.contains(key) && !row.at(key).is_null() && row.at(key).is_string();
+}
+
+static bool json_has_bool(const json & row, const char * key) {
+    return row.contains(key) && !row.at(key).is_null() && row.at(key).is_boolean();
+}
+
+static bool action_accepts_proxy(const common_sage_policy_result & result) {
+    return std::strcmp(result.action, "accept_proxy") == 0;
+}
+
+static void add_scheduler_fields(json & out, const json & row, const common_sage_policy_result & result) {
+    const bool has_proxy_token = json_has_string(row, "proxy_token");
+    const bool has_oracle_token = json_has_string(row, "oracle_token");
+
+    std::string proxy_token;
+    std::string oracle_token;
+    if (has_proxy_token) {
+        proxy_token = row.at("proxy_token").get<std::string>();
+        out["proxy_token"] = proxy_token;
+    }
+    if (has_oracle_token) {
+        oracle_token = row.at("oracle_token").get<std::string>();
+        out["oracle_token"] = oracle_token;
+    }
+    if (has_proxy_token && has_oracle_token) {
+        out["selected_token"] = action_accepts_proxy(result) ? proxy_token : oracle_token;
+    }
+
+    bool has_top1_match = false;
+    bool top1_match = false;
+    if (json_has_bool(row, "top1_match")) {
+        has_top1_match = true;
+        top1_match = row.at("top1_match").get<bool>();
+    } else if (json_has_bool(row, "replay_top1_token_match")) {
+        has_top1_match = true;
+        top1_match = row.at("replay_top1_token_match").get<bool>();
+    }
+
+    if (has_top1_match) {
+        out["top1_match"] = top1_match;
+        out["false_accept"] = action_accepts_proxy(result) && !top1_match;
+    } else if (has_proxy_token || has_oracle_token) {
+        out["top1_match"] = nullptr;
+        out["false_accept"] = nullptr;
+    }
+}
+
 static void print_decision_json(const common_sage_policy_input & input, const common_sage_policy_result & result) {
     std::printf("%s\n", decision_to_json(input, result).dump().c_str());
 }
