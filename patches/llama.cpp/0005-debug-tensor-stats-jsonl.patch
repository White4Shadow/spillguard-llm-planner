+static void common_debug_write_tensor_stats_jsonl(
+        std::ostream &                    out,
+        int64_t                           sequence,
+        const struct ggml_tensor *        t,
+        const common_debug_tensor_stats & stats) {
+    out << "{\"sequence\":" << (long long) sequence;
+    out << ",\"name\":";
+    common_debug_write_json_string(out, t->name);
+    out << ",\"dtype\":";
+    common_debug_write_json_string(out, ggml_type_name(t->type));
+    out << ",\"op\":";
+    common_debug_write_json_string(out, ggml_op_desc(t));
+    out << ",\"shape\":[";
+    for (int i = 0; i < GGML_MAX_DIMS; ++i) {
+        if (i > 0) {
+            out << ',';
+        }
+        out << (long long) t->ne[i];
+    }
+    out << "],\"count\":" << (long long) stats.count;
+    out << ",\"sum\":";
+    common_debug_write_json_number(out, stats.sum);
+    out << ",\"mean\":";
+    common_debug_write_json_number(out, stats.mean);
+    out << ",\"min\":";
+    common_debug_write_json_number(out, stats.min_value);
+    out << ",\"max\":";
+    common_debug_write_json_number(out, stats.max_value);
+    out << ",\"nan_count\":" << (long long) stats.nan_count << "}\n";
+}
