+static void common_debug_write_json_string(std::ostream & out, const char * value) {
+    out << '"';
+    for (const char * p = value; *p != '\0'; ++p) {
+        const unsigned char c = (unsigned char) *p;
+        switch (c) {
+            case '"':  out << "\\\""; break;
+            case '\\': out << "\\\\"; break;
+            case '\b': out << "\\b";  break;
+            case '\f': out << "\\f";  break;
+            case '\n': out << "\\n";  break;
+            case '\r': out << "\\r";  break;
+            case '\t': out << "\\t";  break;
+            default:
+                out << (c < 0x20 ? '?' : (char) c);
+                break;
+        }
+    }
+    out << '"';
+}
+
+static void common_debug_write_json_number(std::ostream & out, double value) {
+    if (std::isfinite(value)) {
+        out << std::setprecision(17) << value;
+    } else {
+        out << "null";
+    }
+}
