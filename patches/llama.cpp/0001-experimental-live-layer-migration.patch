+int llama_model::migrate_layer(int il, ggml_backend_dev_t dev) {
+    if (!pimpl->live_layer_buffers) {
+        LLAMA_LOG_ERROR("%s: model was not loaded with LLAMA_EXPERIMENTAL_LAYER_BUFFERS=1\n", __func__);
+        return -2;
+    }
+    if (il < 0 || il >= (int) layers.size()) {
+        LLAMA_LOG_ERROR("%s: invalid layer %d\n", __func__, il);
+        return -1;
+    }
+    if (!dev) {
+        LLAMA_LOG_ERROR("%s: target device is null\n", __func__);
+        return -1;
+    }
+
+    ggml_backend_buffer_type_t dst_buft = nullptr;
+    buft_list_t * dst_buft_list = nullptr;
+    if (ggml_backend_dev_type(dev) == GGML_BACKEND_DEVICE_TYPE_CPU) {
+        dst_buft = ggml_backend_cpu_buffer_type();
+        dst_buft_list = &pimpl->cpu_buft_list;
+    } else {
+        auto it = pimpl->gpu_buft_list.find(dev);
+        if (it == pimpl->gpu_buft_list.end()) {
+            LLAMA_LOG_ERROR("%s: target device %s is not part of this model\n", __func__, ggml_backend_dev_name(dev));
+            return -1;
+        }
+        dst_buft = ggml_backend_dev_buffer_type(dev);
+        dst_buft_list = &it->second;
+    }
+    if (!dst_buft) {
+        LLAMA_LOG_ERROR("%s: target device %s has no default buffer type\n", __func__, ggml_backend_dev_name(dev));
+        return -1;
+    }
+
+    if (pimpl->dev_layer.at(il).dev == dev) {
+        LLAMA_LOG_DEBUG("%s: layer %d already on %s\n", __func__, il, ggml_backend_dev_name(dev));
+        return 0;
+    }
+
+    if (il >= (int) pimpl->layer_ctxs.size() || pimpl->layer_ctxs[il].empty()) {
+        LLAMA_LOG_ERROR("%s: layer %d has no isolated migration buffer\n", __func__, il);
+        return -2;
+    }
+
+    auto slots = llama_layer_tensor_slots(layers[il]);
+    std::vector<ggml_tensor *> src_tensors;
+    src_tensors.reserve(slots.size());
+    for (auto ** slot : slots) {
+        if (*slot == nullptr) {
+            continue;
+        }
+        if (std::find(src_tensors.begin(), src_tensors.end(), *slot) == src_tensors.end()) {
+            src_tensors.push_back(*slot);
+        }
+    }
+
+    if (src_tensors.empty()) {
+        LLAMA_LOG_ERROR("%s: layer %d has no tensors to migrate\n", __func__, il);
+        return -2;
+    }
+
+    ggml_init_params params = {
+        /*.mem_size   =*/ ggml_tensor_overhead()*(src_tensors.size() + 8),
+        /*.mem_buffer =*/ NULL,
+        /*.no_alloc   =*/ true,
+    };
+
+    ggml_context_ptr dst_ctx { ggml_init(params) };
+    if (!dst_ctx) {
+        LLAMA_LOG_ERROR("%s: failed to create destination context for layer %d\n", __func__, il);
+        return -3;
+    }
+
+    std::unordered_map<ggml_tensor *, ggml_tensor *> replacements;
+    replacements.reserve(src_tensors.size());
+    for (ggml_tensor * src : src_tensors) {
+        ggml_tensor * dst = ggml_dup_tensor(dst_ctx.get(), src);
+        ggml_set_name(dst, ggml_get_name(src));
+        replacements.emplace(src, dst);
+    }
+
+    ggml_backend_buffer_ptr dst_buf { ggml_backend_alloc_ctx_tensors_from_buft(dst_ctx.get(), dst_buft) };
+    if (!dst_buf) {
+        LLAMA_LOG_ERROR("%s: failed to allocate %s buffer for layer %d\n", __func__, ggml_backend_buft_name(dst_buft), il);
+        return -3;
+    }
+    ggml_backend_buffer_set_usage(dst_buf.get(), GGML_BACKEND_BUFFER_USAGE_WEIGHTS);
+
+    for (auto & [src, dst] : replacements) {
+        ggml_backend_tensor_copy(src, dst);
+    }
+
+    for (auto ** slot : slots) {
+        auto it = replacements.find(*slot);
+        if (it != replacements.end()) {
+            *slot = it->second;
+        }
+    }
+    for (auto & [name, tensor] : tensors_by_name) {
+        auto it = replacements.find(tensor);
+        if (it != replacements.end()) {
+            tensor = it->second;
+        }
+    }
+
+    const size_t dst_idx = pimpl->ctxs_bufs.size();
+    std::vector<ggml_backend_buffer_ptr> dst_bufs;
+    dst_bufs.emplace_back(std::move(dst_buf));
+    pimpl->ctxs_bufs.emplace_back(std::move(dst_ctx), std::move(dst_bufs));
+
+    for (size_t idx : pimpl->layer_ctxs[il]) {
+        if (idx < pimpl->ctxs_bufs.size()) {
+            pimpl->ctxs_bufs[idx].second.clear();
+            pimpl->ctxs_bufs[idx].first.reset();
+        }
+    }
+    pimpl->layer_ctxs[il].clear();
+    pimpl->layer_ctxs[il].push_back(dst_idx);
+    pimpl->dev_layer[il] = { dev, dst_buft_list };
+
+    LLAMA_LOG_INFO("%s: migrated layer %d to %s (%s, %.2f MiB)\n",
+            __func__, il, ggml_backend_dev_name(dev), ggml_backend_buft_name(dst_buft),
+            ggml_backend_buffer_get_size(pimpl->ctxs_bufs[dst_idx].second.front().get()) / 1024.0 / 1024.0);
+
+    return 0;
+}
