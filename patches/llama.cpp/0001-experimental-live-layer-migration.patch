+static size_t llama_env_mib(const char * name, size_t fallback_mib) {
+    const char * value = std::getenv(name);
+    if (!value || value[0] == '\0') {
+        return fallback_mib*1024ull*1024ull;
+    }
+    const long long parsed = std::atoll(value);
+    return parsed > 0 ? (size_t) parsed*1024ull*1024ull : fallback_mib*1024ull*1024ull;
+}
+
+static int llama_env_int(const char * name, int fallback) {
+    const char * value = std::getenv(name);
+    if (!value || value[0] == '\0') {
+        return fallback;
+    }
+    const int parsed = std::atoi(value);
+    return parsed > 0 ? parsed : fallback;
+}
+
+static double llama_env_percent(const char * name, double fallback) {
+    const char * value = std::getenv(name);
+    if (!value || value[0] == '\0') {
+        return fallback;
+    }
+    const double parsed = std::atof(value);
+    return parsed > 0.0 && parsed <= 100.0 ? parsed : fallback;
+}
+
+static bool llama_cpu_times(uint64_t & idle, uint64_t & total) {
+#ifdef _WIN32
+    FILETIME idle_time;
+    FILETIME kernel_time;
+    FILETIME user_time;
+    if (!GetSystemTimes(&idle_time, &kernel_time, &user_time)) {
+        return false;
+    }
+
+    auto filetime_to_u64 = [](const FILETIME & ft) -> uint64_t {
+        ULARGE_INTEGER value;
+        value.LowPart = ft.dwLowDateTime;
+        value.HighPart = ft.dwHighDateTime;
+        return value.QuadPart;
+    };
+
+    idle  = filetime_to_u64(idle_time);
+    total = filetime_to_u64(kernel_time) + filetime_to_u64(user_time);
+    return true;
+#else
+    std::ifstream stat("/proc/stat");
+    std::string line;
+    if (!std::getline(stat, line)) {
+        return false;
+    }
+
+    std::istringstream iss(line);
+    std::string cpu;
+    uint64_t user = 0;
+    uint64_t nice = 0;
+    uint64_t system = 0;
+    uint64_t idle_time = 0;
+    uint64_t iowait = 0;
+    uint64_t irq = 0;
+    uint64_t softirq = 0;
+    uint64_t steal = 0;
+    iss >> cpu >> user >> nice >> system >> idle_time >> iowait >> irq >> softirq >> steal;
+    if (cpu != "cpu") {
+        return false;
+    }
+
+    idle  = idle_time + iowait;
+    total = user + nice + system + idle_time + iowait + irq + softirq + steal;
+    return true;
+#endif
+}
+
+static bool llama_cpu_load_sample(uint64_t & prev_idle, uint64_t & prev_total, bool & ready, double & load) {
+    uint64_t idle = 0;
+    uint64_t total = 0;
+    if (!llama_cpu_times(idle, total)) {
+        return false;
+    }
+
+    if (!ready) {
+        prev_idle = idle;
+        prev_total = total;
+        ready = true;
+        return false;
+    }
+
+    if (total <= prev_total) {
+        prev_idle = idle;
+        prev_total = total;
+        return false;
+    }
+
+    const uint64_t idle_delta = idle - prev_idle;
+    const uint64_t total_delta = total - prev_total;
+
+    prev_idle = idle;
+    prev_total = total;
+
+    if (total_delta == 0 || idle_delta > total_delta) {
+        return false;
+    }
+
+    load = 1.0 - (double) idle_delta / (double) total_delta;
+    if (load < 0.0) {
+        load = 0.0;
+    }
+    if (load > 1.0) {
+        load = 1.0;
+    }
+    return true;
+}
+
+void llama_context::live_migration_init() {
+    const char * enabled = std::getenv("LLAMA_LIVE_MIGRATION");
+    live_migration.enabled = enabled && std::atoi(enabled) != 0;
+    if (!live_migration.enabled) {
+        return;
+    }
+
+    if (!model.supports_live_layer_migration()) {
+        LLAMA_LOG_WARN("%s: LLAMA_LIVE_MIGRATION requires LLAMA_EXPERIMENTAL_LAYER_BUFFERS=1; disabling live migration policy\n", __func__);
+        live_migration.enabled = false;
+        live_migration.warned_unsupported = true;
+        return;
+    }
+
+    for (size_t i = 0; i < model.devices.size(); ++i) {
+        auto * dev = model.devices[i].dev;
+        if (dev && ggml_backend_dev_type(dev) != GGML_BACKEND_DEVICE_TYPE_CPU) {
+            live_migration.device = dev;
+            live_migration.device_index = (int) i;
+            break;
+        }
+    }
+
+    if (!live_migration.device) {
+        LLAMA_LOG_WARN("%s: no non-CPU model device is available; disabling live migration policy\n", __func__);
+        live_migration.enabled = false;
+        return;
+    }
+
+    live_migration.min_free_vram     = llama_env_mib("LLAMA_LIVE_MIGRATION_MIN_FREE_MB", 768);
+    live_migration.restore_free_vram = llama_env_mib("LLAMA_LIVE_MIGRATION_RESTORE_FREE_MB", 2048);
+    live_migration.min_free_ram      = llama_env_mib("LLAMA_LIVE_MIGRATION_MIN_RAM_FREE_MB", 2048);
+    live_migration.max_cpu_load      = llama_env_percent("LLAMA_LIVE_MIGRATION_MAX_CPU_PCT", 85.0) / 100.0;
+    live_migration.interval_decodes  = llama_env_int("LLAMA_LIVE_MIGRATION_INTERVAL_DECODE", 1);
+    live_migration.demote_cursor     = (int) model.hparams.n_layer_all - 1;
+    llama_cpu_load_sample(live_migration.cpu_prev_idle, live_migration.cpu_prev_total, live_migration.cpu_sample_ready, live_migration.last_cpu_load);
+
+    if (live_migration.restore_free_vram <= live_migration.min_free_vram) {
+        live_migration.restore_free_vram = live_migration.min_free_vram + 512ull*1024ull*1024ull;
+    }
+
+    LLAMA_LOG_WARN("%s: live migration policy enabled for %s: demote below %.2f MiB free VRAM, restore above %.2f MiB, min CPU RAM %.2f MiB, max CPU %.1f%%, interval %d decode calls\n",
+            __func__,
+            ggml_backend_dev_name(live_migration.device),
+            live_migration.min_free_vram/1024.0/1024.0,
+            live_migration.restore_free_vram/1024.0/1024.0,
+            live_migration.min_free_ram/1024.0/1024.0,
+            live_migration.max_cpu_load*100.0,
+            live_migration.interval_decodes);
+}
+
+void llama_context::live_migration_tick() {
+    if (!live_migration.enabled) {
+        return;
+    }
+
+    live_migration.decode_counter++;
+    if (live_migration.decode_counter % live_migration.interval_decodes != 0) {
+        return;
+    }
+
+    size_t free_vram = 0;
+    size_t total_vram = 0;
+    ggml_backend_dev_memory(live_migration.device, &free_vram, &total_vram);
+    if (total_vram == 0) {
+        return;
+    }
+
+    double cpu_load = -1.0;
+    if (llama_cpu_load_sample(live_migration.cpu_prev_idle, live_migration.cpu_prev_total, live_migration.cpu_sample_ready, cpu_load)) {
+        live_migration.last_cpu_load = cpu_load;
+    }
+
+    if (free_vram < live_migration.min_free_vram) {
+        if (live_migration.last_cpu_load >= 0.0 && live_migration.last_cpu_load >= live_migration.max_cpu_load) {
+            LLAMA_LOG_WARN("%s: low VRAM but CPU is already busy; skip demotion (VRAM %.2f MiB free, CPU %.1f%%)\n",
+                    __func__, free_vram/1024.0/1024.0, live_migration.last_cpu_load*100.0);
+            return;
+        }
+
+        ggml_backend_dev_t cpu_dev = ggml_backend_dev_by_type(GGML_BACKEND_DEVICE_TYPE_CPU);
+        if (cpu_dev) {
+            size_t free_ram = 0;
+            size_t total_ram = 0;
+            ggml_backend_dev_memory(cpu_dev, &free_ram, &total_ram);
+            if (total_ram != 0 && free_ram < live_migration.min_free_ram) {
+                LLAMA_LOG_WARN("%s: low VRAM but CPU RAM is also low; skip demotion (VRAM %.2f MiB free, RAM %.2f MiB free)\n",
+                        __func__, free_vram/1024.0/1024.0, free_ram/1024.0/1024.0);
+                return;
+            }
+        }
+
+        const int n_layer = (int) model.hparams.n_layer_all;
+        if (n_layer <= 0) {
+            return;
+        }
+        int cursor = live_migration.demote_cursor;
+        if (cursor < 0 || cursor >= n_layer) {
+            cursor = n_layer - 1;
+        }
+
+        for (int attempt = 0; attempt < n_layer; ++attempt) {
+            const int il = (cursor - attempt + n_layer) % n_layer;
+            if (model.dev_layer(il) != live_migration.device) {
+                continue;
+            }
+
+            LLAMA_LOG_WARN("%s: VRAM pressure on %s (%.2f MiB free, CPU %.1f%%); demoting layer %d to CPU\n",
+                    __func__, ggml_backend_dev_name(live_migration.device), free_vram/1024.0/1024.0,
+                    live_migration.last_cpu_load >= 0.0 ? live_migration.last_cpu_load*100.0 : -1.0, il);
+
+            if (live_migrate_layer(il, -1) == 0) {
+                live_migration.demoted_layers.push_back(il);
+                live_migration.demote_cursor = il - 1;
+            }
+            return;
+        }
+
+        LLAMA_LOG_WARN("%s: VRAM pressure on %s but no GPU-resident layer is available to demote\n",
+                __func__, ggml_backend_dev_name(live_migration.device));
+        return;
+    }
+
+    if (free_vram > live_migration.restore_free_vram && !live_migration.demoted_layers.empty()) {
+        const int il = live_migration.demoted_layers.back();
+        LLAMA_LOG_WARN("%s: VRAM recovered on %s (%.2f MiB free, CPU %.1f%%); promoting layer %d back to GPU\n",
+                __func__, ggml_backend_dev_name(live_migration.device), free_vram/1024.0/1024.0,
+                live_migration.last_cpu_load >= 0.0 ? live_migration.last_cpu_load*100.0 : -1.0, il);
+
+        if (live_migrate_layer(il, live_migration.device_index) == 0) {
+            live_migration.demoted_layers.pop_back();
+            live_migration.demote_cursor = il - 1;
+        }
+    }
+}
+
