+static std::vector<ggml_tensor **> llama_layer_tensor_slots(llama_layer & layer) {
+    std::vector<ggml_tensor **> slots;
+    slots.reserve(sizeof(layer)/sizeof(struct ggml_tensor *));
+    for (size_t i = 0; i < sizeof(layer)/sizeof(struct ggml_tensor *); ++i) {
+        slots.push_back(&reinterpret_cast<struct ggml_tensor **>(&layer)[i]);
+    }
+    return slots;
+}
