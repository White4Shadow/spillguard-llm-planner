+void llama_context::live_migration_init() {
+    const char * enabled = std::getenv("LLAMA_LIVE_MIGRATION");
+    live_migration.enabled = enabled && std::atoi(enabled) != 0;
+    if (!live_migration.enabled) {
+        return;
+    }
+
+    if (!model.supports_live_layer_migration()) {
+        LLAMA_LOG_WARN("%s: LLAMA_LIVE_MIGRATION requires LLAMA_EXPERIMENTAL_LAYER_BUFFERS=1; disabling live migration policy\n", __func__);
+        live_migration.enabled = false;
+        live_migration.warned_unsupported = true;
+        return;
+    }
+
+    for (size_t i = 0; i < model.devices.size(); ++i) {
+        auto * dev = model.devices[i].dev;
+        if (dev && ggml_backend_dev_type(dev) != GGML_BACKEND_DEVICE_TYPE_CPU) {
+            live_migration.device = dev;
+            live_migration.device_index = (int) i;
+            break;
+        }
+    }
+
+    if (!live_migration.device) {
+        LLAMA_LOG_WARN("%s: no non-CPU model device is available; disabling live migration policy\n", __func__);
+        live_migration.enabled = false;
+        return;
+    }
+
+    live_migration.min_free_vram     = llama_env_mib("LLAMA_LIVE_MIGRATION_MIN_FREE_MB", 768);
+    live_migration.restore_free_vram = llama_env_mib("LLAMA_LIVE_MIGRATION_RESTORE_FREE_MB", 2048);
+    live_migration.min_free_ram      = llama_env_mib("LLAMA_LIVE_MIGRATION_MIN_RAM_FREE_MB", 2048);
+    live_migration.interval_decodes  = llama_env_int("LLAMA_LIVE_MIGRATION_INTERVAL_DECODE", 1);
+    live_migration.demote_cursor     = (int) model.hparams.n_layer_all - 1;
+
+    if (live_migration.restore_free_vram <= live_migration.min_free_vram) {
+        live_migration.restore_free_vram = live_migration.min_free_vram + 512ull*1024ull*1024ull;
+    }
+
+    LLAMA_LOG_WARN("%s: live migration policy enabled for %s: demote below %.2f MiB free VRAM, restore above %.2f MiB, min CPU RAM %.2f MiB, interval %d decode calls\n",
+            __func__,
+            ggml_backend_dev_name(live_migration.device),
+            live_migration.min_free_vram/1024.0/1024.0,
+            live_migration.restore_free_vram/1024.0/1024.0,
+            live_migration.min_free_ram/1024.0/1024.0,
+            live_migration.interval_decodes);
+}
+
+void llama_context::live_migration_tick() {
+    if (!live_migration.enabled) {
+        return;
+    }
+
+    live_migration.decode_counter++;
+    if (live_migration.decode_counter % live_migration.interval_decodes != 0) {
+        return;
+    }
+
+    size_t free_vram = 0;
+    size_t total_vram = 0;
+    ggml_backend_dev_memory(live_migration.device, &free_vram, &total_vram);
+    if (total_vram == 0) {
+        return;
+    }
+
+    if (free_vram < live_migration.min_free_vram) {
+        ggml_backend_dev_t cpu_dev = ggml_backend_dev_by_type(GGML_BACKEND_DEVICE_TYPE_CPU);
+        if (cpu_dev) {
+            size_t free_ram = 0;
+            size_t total_ram = 0;
+            ggml_backend_dev_memory(cpu_dev, &free_ram, &total_ram);
+            if (total_ram != 0 && free_ram < live_migration.min_free_ram) {
+                LLAMA_LOG_WARN("%s: low VRAM but CPU RAM is also low; skip demotion (VRAM %.2f MiB free, RAM %.2f MiB free)\n",
+                        __func__, free_vram/1024.0/1024.0, free_ram/1024.0/1024.0);
+                return;
+            }
+        }
+
+        const int n_layer = (int) model.hparams.n_layer_all;
+        if (n_layer <= 0) {
+            return;
+        }
+        int cursor = live_migration.demote_cursor;
+        if (cursor < 0 || cursor >= n_layer) {
+            cursor = n_layer - 1;
+        }
+
+        for (int attempt = 0; attempt < n_layer; ++attempt) {
+            const int il = (cursor - attempt + n_layer) % n_layer;
+            if (model.dev_layer(il) != live_migration.device) {
+                continue;
+            }
+
+            LLAMA_LOG_WARN("%s: VRAM pressure on %s (%.2f MiB free); demoting layer %d to CPU\n",
+                    __func__, ggml_backend_dev_name(live_migration.device), free_vram/1024.0/1024.0, il);
+
+            if (live_migrate_layer(il, -1) == 0) {
+                live_migration.demoted_layers.push_back(il);
+                live_migration.demote_cursor = il - 1;
+            }
+            return;
+        }
+
+        LLAMA_LOG_WARN("%s: VRAM pressure on %s but no GPU-resident layer is available to demote\n",
+                __func__, ggml_backend_dev_name(live_migration.device));
+        return;
+    }
+
+    if (free_vram > live_migration.restore_free_vram && !live_migration.demoted_layers.empty()) {
+        const int il = live_migration.demoted_layers.back();
+        LLAMA_LOG_WARN("%s: VRAM recovered on %s (%.2f MiB free); promoting layer %d back to GPU\n",
+                __func__, ggml_backend_dev_name(live_migration.device), free_vram/1024.0/1024.0, il);
+
+        if (live_migrate_layer(il, live_migration.device_index) == 0) {
+            live_migration.demoted_layers.pop_back();
+            live_migration.demote_cursor = il - 1;
+        }
+    }
+}
