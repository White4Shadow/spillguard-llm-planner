+int llama_context::live_migrate_layer(int il, int device) {
+    ggml_backend_dev_t dev = nullptr;
+    if (device < 0) {
+        dev = ggml_backend_dev_by_type(GGML_BACKEND_DEVICE_TYPE_CPU);
+    } else if (device < (int) model.devices.size()) {
+        dev = model.devices[device].dev;
+    }
+
+    if (!dev) {
+        LLAMA_LOG_ERROR("%s: invalid target device index %d\n", __func__, device);
+        return -1;
+    }
+
+    synchronize();
+
+    const int ret = const_cast<llama_model &>(model).migrate_layer(il, dev);
+    if (ret != 0) {
+        return ret;
+    }
+
+    if (sched) {
+        ggml_backend_sched_reset(sched.get());
+    }
+    if (gf_res_prev) {
+        gf_res_prev->reset();
+    }
+    sched_need_reserve = true;
+
     return 0;
 }
 
