+static size_t llama_env_mib(const char * name, size_t fallback_mib) {
+    const char * value = std::getenv(name);
+    if (!value || value[0] == '\0') {
+        return fallback_mib*1024ull*1024ull;
+    }
+    const long long parsed = std::atoll(value);
+    return parsed > 0 ? (size_t) parsed*1024ull*1024ull : fallback_mib*1024ull*1024ull;
+}
+
+static int llama_env_int(const char * name, int fallback) {
+    const char * value = std::getenv(name);
+    if (!value || value[0] == '\0') {
+        return fallback;
+    }
+    const int parsed = std::atoi(value);
+    return parsed > 0 ? parsed : fallback;
+}
