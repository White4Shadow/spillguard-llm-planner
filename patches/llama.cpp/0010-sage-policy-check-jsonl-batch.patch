+static int run_jsonl(const std::string & input_path, const std::string & output_path) {
+    std::ifstream input(input_path);
+    if (!input.is_open()) {
+        std::fprintf(stderr, "failed to open --jsonl-in: %s\n", input_path.c_str());
+        return 1;
+    }
+
+    std::ofstream output_file;
+    std::ostream * output = &std::cout;
+    if (!output_path.empty() && output_path != "-") {
+        output_file.open(output_path, std::ios::out | std::ios::trunc);
+        if (!output_file.is_open()) {
+            std::fprintf(stderr, "failed to open --jsonl-out: %s\n", output_path.c_str());
+            return 1;
+        }
+        output = &output_file;
+    }
+
+    std::string line;
+    size_t line_number = 0;
+    while (std::getline(input, line)) {
+        line_number++;
+        if (line.empty()) {
+            continue;
+        }
+        try {
+            const json row = json::parse(line);
+            const common_sage_policy_input policy_input = input_from_json(row);
+            const common_sage_policy_result result = common_sage_decide(policy_input);
+            (*output) << decision_to_json(policy_input, result).dump() << '\n';
+        } catch (const std::exception & e) {
+            std::fprintf(stderr, "failed to process JSONL line %zu: %s\n", line_number, e.what());
+            return 1;
+        }
+    }
+    output->flush();
+    return 0;
 }
 
