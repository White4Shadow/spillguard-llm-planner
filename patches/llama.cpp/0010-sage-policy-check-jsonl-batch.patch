+static common_sage_policy_input input_from_json(const json & row) {
+    common_sage_policy_input input;
+    input.candidate_id = row.value("candidate_id", "");
+    input.token_class = row.at("token_class").get<std::string>();
+    input.proxy_entropy = row.at("proxy_entropy").get<double>();
+    input.proxy_margin = row.at("proxy_margin").get<double>();
+    if (row.contains("ffn_norm_0_sequence") && !row.at("ffn_norm_0_sequence").is_null()) {
+        input.ffn_norm_0_sequence = row.at("ffn_norm_0_sequence").get<int64_t>();
+    }
+    if (row.contains("ffn_norm_0_sum") && !row.at("ffn_norm_0_sum").is_null()) {
+        input.ffn_norm_0_sum = row.at("ffn_norm_0_sum").get<double>();
+        input.has_ffn_norm_0 = true;
+    }
+    return input;
+}
