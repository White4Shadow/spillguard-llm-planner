+common_sage_policy_result common_sage_decide(const common_sage_policy_input & input) {
+    common_sage_policy_result result;
+    result.proxy_gate_accept = input.proxy_entropy <= 0.6 || input.proxy_margin >= 1.5;
+    result.verifier_needed = result.proxy_gate_accept &&
+            (input.token_class == "punct" || input.token_class == "capitalized");
+    result.verifier_covered = result.verifier_needed && input.has_ffn_norm_0;
+    result.verifier_accept = result.verifier_covered &&
+            (input.proxy_entropy <= 0.040003470206379677 ||
+             input.ffn_norm_0_sum >= -72.150276000000005);
+
+    if (result.proxy_gate_accept && !result.verifier_needed) {
+        result.action = "accept_proxy";
+        result.reason = "proxy_gate_non_verifier_class";
+    } else if (result.verifier_needed && !result.verifier_covered) {
+        result.reason = "missing_runtime_signal";
+    } else if (result.verifier_needed && result.verifier_accept) {
+        result.action = "accept_proxy";
+        result.reason = "runtime_verifier_accept";
+    } else if (result.verifier_needed) {
+        result.reason = "runtime_verifier_reject";
+    }
+
+    return result;
+}
