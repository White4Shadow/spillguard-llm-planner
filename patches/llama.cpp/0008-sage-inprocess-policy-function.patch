+static void common_sage_write_decision_jsonl(
+        std::ostream &                         out,
+        const common_sage_policy_input &       input,
+        const common_sage_policy_result &      result) {
+    out << "{\"candidate_id\":";
+    common_sage_write_json_string(out, input.candidate_id.c_str());
+    out << ",\"token_class\":";
+    common_sage_write_json_string(out, input.token_class.c_str());
+    out << ",\"proxy_entropy\":";
+    common_sage_write_json_number(out, input.proxy_entropy);
+    out << ",\"proxy_margin\":";
+    common_sage_write_json_number(out, input.proxy_margin);
+    out << ",\"proxy_gate_accept\":" << (result.proxy_gate_accept ? "true" : "false");
+    out << ",\"verifier_needed\":" << (result.verifier_needed ? "true" : "false");
+    out << ",\"verifier_covered\":" << (result.verifier_covered ? "true" : "false");
+    out << ",\"verifier_accept\":";
+    if (result.verifier_covered) {
+        out << (result.verifier_accept ? "true" : "false");
+    } else {
+        out << "null";
+    }
+    out << ",\"ffn_norm_0_sequence\":" << (long long) input.ffn_norm_0_sequence;
+    out << ",\"ffn_norm_0_sum\":";
+    if (input.has_ffn_norm_0) {
+        common_sage_write_json_number(out, input.ffn_norm_0_sum);
+    } else {
+        out << "null";
+    }
+    out << ",\"action\":";
+    common_sage_write_json_string(out, result.action);
+    out << ",\"reason\":";
+    common_sage_write_json_string(out, result.reason);
+    out << "}\n";
+}
